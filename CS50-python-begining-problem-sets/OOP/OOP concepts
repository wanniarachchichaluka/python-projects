SECTION 10: COMPLETE REFERENCE EXAMPLE
===============================================================================
class Wizard:
    VALID_HOUSES = ["Gryffindor", "Hufflepuff", "Ravenclaw", "Slytherin"]

    def __init__(self, name):
        if not name: raise ValueError("Missing name")
        self._name = name

    @property
    def name(self): return self._name

    @name.setter
    def name(self, name):
        if not name: raise ValueError("Invalid name")
        self._name = name

    def __str__(self): return f"Wizard: {self.name}"

class Student(Wizard):
    def __init__(self, name, house, patronus=None):
        super().__init__(name)
        self.house = house
        self.patronus = patronus

    @property
    def house(self): return self._house

    @house.setter
    def house(self, house):
        if house not in Wizard.VALID_HOUSES:
            raise ValueError(f"Invalid house: {house}")
        self._house = house

    def charm(self):
        match self.patronus:
            case "Stag": return "🤣"
            case _: return "🤩"

    @classmethod
    def get(cls):
        return cls(input("Name: "), input("House: "), input("Patronus: "))

    def __str__(self): return f"{self.name} from {self.house}"

def main():
    try:
        student = Student.get()
        print(student)
        print(f"Charm: {student.charm()}")
    except ValueError as e:
        print(f"Error: {e}")

if __name__ == "__main__":
    main()

